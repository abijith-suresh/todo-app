{
  "name": "todo-app",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "astro sync && tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "bun run type-check && bun run lint && bun run format:check && bun run test && bun run build",
    "prepare": "test -d .git && husky || true"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx,astro,css,json}": [
      "bunx biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@astrojs/solid-js": "^6.0.1",
    "astro": "^7.1.1",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^25.9.1",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  }
}
