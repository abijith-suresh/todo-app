---
export interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "light";
  class?: string;
}

const { href, variant = "primary", class: className = "" } = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center px-8 py-[0.9rem] font-body text-[0.9375rem] font-medium rounded-[2px] transition-all duration-300 ease-out cursor-pointer border-none";

const variantClasses = {
  primary:
    "bg-accent text-card shadow-soft hover:bg-accent-hover hover:shadow-medium hover:-translate-y-0.5",
  secondary:
    "bg-transparent text-ink-secondary border border-line hover:border-ink-secondary hover:text-ink hover:-translate-y-0.5",
  light:
    "bg-card text-accent shadow-soft hover:bg-card/90 hover:text-accent-hover hover:shadow-medium hover:-translate-y-0.5",
};
---

{
  href ? (
    <a href={href} class={`${baseClasses} ${variantClasses[variant]} ${className}`}>
      <slot />
    </a>
  ) : (
    <button class={`${baseClasses} ${variantClasses[variant]} ${className}`}>
      <slot />
    </button>
  )
}
