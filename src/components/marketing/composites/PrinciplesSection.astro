---
import SectionInner from "@/components/ui/Astro/SectionInner.astro";
---

<section class="px-8 py-28 max-lg:py-20 max-sm:px-5 relative bg-mk-accent-bg text-mk-paper">
  <SectionInner>
    <div class="mb-12 animate-mk-fade-in-up duration-[800ms] delay-[100ms]">
      <span class="font-mk-display text-sm tracking-wider block mb-3 text-mk-accent">02</span>
      <h2
        class="font-mk-display text-[clamp(2rem,4vw,3rem)] font-normal leading-[1.15] tracking-tight text-mk-paper"
      >
        What we believe
      </h2>
    </div>
    <div class="grid grid-cols-2 gap-10 max-lg:grid-cols-1 max-lg:gap-8">
      <div class="animate-mk-fade-in-up duration-[700ms] delay-[100ms]">
        <h3 class="font-mk-display text-xl font-normal text-mk-paper mb-3">Local-first</h3>
        <p
          class="font-mk-body text-[0.95rem] font-light leading-relaxed text-[rgba(250,249,246,0.65)]"
        >
          Your data lives in your browser. We don&rsquo;t store anything on our servers because
          there are no servers.
        </p>
      </div>
      <div class="animate-mk-fade-in-up duration-[700ms] delay-[200ms]">
        <h3 class="font-mk-display text-xl font-normal text-mk-paper mb-3">Friction-free</h3>
        <p
          class="font-mk-body text-[0.95rem] font-light leading-relaxed text-[rgba(250,249,246,0.65)]"
        >
          No sign-up forms. No onboarding wizards. Open the page and start writing.
        </p>
      </div>
      <div class="animate-mk-fade-in-up duration-[700ms] delay-[300ms]">
        <h3 class="font-mk-display text-xl font-normal text-mk-paper mb-3">Today, only today</h3>
        <p
          class="font-mk-body text-[0.95rem] font-light leading-relaxed text-[rgba(250,249,246,0.65)]"
        >
          We don&rsquo;t do recurring tasks, Gantt charts, or team collaboration. This is a single
          page for a single day.
        </p>
      </div>
      <div class="animate-mk-fade-in-up duration-[700ms] delay-[400ms]">
        <h3 class="font-mk-display text-xl font-normal text-mk-paper mb-3">Quiet by design</h3>
        <p
          class="font-mk-body text-[0.95rem] font-light leading-relaxed text-[rgba(250,249,246,0.65)]"
        >
          No badges, no red dots, no urgency. If it matters, you&rsquo;ll remember it. The rest can
          wait.
        </p>
      </div>
    </div>
  </SectionInner>
</section>
