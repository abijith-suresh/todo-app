---
import SectionInner from "../atoms/SectionInner.astro";
---

<section class="px-8 py-28 max-lg:py-20 max-sm:px-5 relative bg-mk-warm">
  <SectionInner>
    <div class="mb-12">
      <span class="font-mk-display text-sm text-mk-accent tracking-wider block mb-3">01</span>
      <h2
        class="font-mk-display text-[clamp(2rem,4vw,3rem)] font-normal leading-[1.15] tracking-tight text-mk-text"
      >
        How it works
      </h2>
    </div>
    <div class="grid grid-cols-3 gap-10 max-lg:grid-cols-1 max-lg:gap-8">
      <div class="animate-mk-fade-in-up duration-[700ms] delay-[100ms]">
        <h3 class="font-mk-display text-xl font-normal text-mk-text mb-3">Open the page</h3>
        <p class="font-mk-body text-[0.95rem] font-light leading-relaxed text-mk-text-secondary">
          No sign-up, no onboarding, no clutter. You land on a clean sheet and the cursor is already
          blinking.
        </p>
      </div>
      <div class="animate-mk-fade-in-up duration-[700ms] delay-[250ms]">
        <h3 class="font-mk-display text-xl font-normal text-mk-text mb-3">Write your intentions</h3>
        <p class="font-mk-body text-[0.95rem] font-light leading-relaxed text-mk-text-secondary">
          Jot down what you want to do today. One line or ten. There is no wrong way to begin.
        </p>
      </div>
      <div class="animate-mk-fade-in-up duration-[700ms] delay-[400ms]">
        <h3 class="font-mk-display text-xl font-normal text-mk-text mb-3">Return as needed</h3>
        <p class="font-mk-body text-[0.95rem] font-light leading-relaxed text-mk-text-secondary">
          Close the tab, open it again. Your today&rsquo;s list is right where you left it &mdash; a
          quiet companion.
        </p>
      </div>
    </div>
  </SectionInner>
</section>
