---
import SectionInner from "@/components/ui/Astro/SectionInner.astro";
---

<section class="px-8 py-28 max-lg:py-20 max-sm:px-5 relative bg-warm">
  <SectionInner>
    <div class="mb-12">
      <span class="font-display text-sm text-accent tracking-wider block mb-3">01</span>
      <h2
        class="font-display text-[clamp(2rem,4vw,3rem)] font-normal leading-[1.15] tracking-tight text-ink"
      >
        How it works
      </h2>
    </div>
    <div class="grid grid-cols-3 gap-10 max-lg:grid-cols-1 max-lg:gap-8">
      <div class="animate-fade-in-up duration-[700ms] delay-[100ms]">
        <h3 class="font-display text-xl font-normal text-ink mb-3">Open the page</h3>
        <p class="font-body text-[0.95rem] font-light leading-relaxed text-ink-secondary">
          No sign-up, no onboarding, no clutter. You land on a clean sheet and the cursor is already
          blinking.
        </p>
      </div>
      <div class="animate-fade-in-up duration-[700ms] delay-[250ms]">
        <h3 class="font-display text-xl font-normal text-ink mb-3">Write your intentions</h3>
        <p class="font-body text-[0.95rem] font-light leading-relaxed text-ink-secondary">
          Jot down what you want to do today. One line or ten. There is no wrong way to begin.
        </p>
      </div>
      <div class="animate-fade-in-up duration-[700ms] delay-[400ms]">
        <h3 class="font-display text-xl font-normal text-ink mb-3">Return as needed</h3>
        <p class="font-body text-[0.95rem] font-light leading-relaxed text-ink-secondary">
          Close the tab, open it again. Your today&rsquo;s list is right where you left it &mdash; a
          quiet companion.
        </p>
      </div>
    </div>
  </SectionInner>
</section>
