---
export interface Props {
  kicker: string;
  titlePrefix: string;
  titleEmphasis: string;
  subtitle: string;
}

const { kicker, titlePrefix, titleEmphasis, subtitle } = Astro.props;
---

<section
  class="min-h-[60vh] flex items-center px-8 py-16 max-sm:px-5 max-sm:pt-28 max-sm:pb-12 relative overflow-hidden"
>
  <div
    class="absolute -top-[20%] -right-[10%] w-[60%] h-[80%] pointer-events-none z-0"
    style="background: radial-gradient(ellipse at center, rgba(237, 234, 227, 0.8) 0%, transparent 70%)"
  >
  </div>
  <div class="max-w-[1000px] mx-auto w-full relative z-1">
    <p
      class="font-mk-body text-xs font-medium uppercase tracking-[0.15em] text-mk-accent mb-6 animate-mk-fade-in-up duration-[600ms] delay-[100ms]"
    >
      {kicker}
    </p>
    <h1
      class="font-mk-display text-[clamp(2.5rem,5vw,4rem)] font-normal leading-[1.1] tracking-tight text-mk-text mb-6 animate-mk-fade-in-up duration-[800ms] delay-[200ms]"
    >
      {titlePrefix}<br /><em class="text-mk-accent italic">{titleEmphasis}</em>
    </h1>
    <p
      class="font-mk-body text-[clamp(1rem,1.4vw,1.15rem)] font-light leading-relaxed text-mk-text-secondary max-w-[520px] animate-mk-fade-in-up duration-[800ms] delay-[350ms]"
    >
      {subtitle}
    </p>
  </div>
</section>
