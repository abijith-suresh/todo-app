---
import Button from "@/components/ui/Astro/Button.astro";
import SectionInner from "@/components/ui/Astro/SectionInner.astro";
---

<section class="px-8 py-28 max-lg:py-20 max-sm:px-5 relative bg-surface-dark text-card">
  <SectionInner>
    <div class="grid grid-cols-[1.2fr_0.8fr] gap-16 items-center max-lg:grid-cols-1 max-lg:gap-8">
      <div class="animate-fade-in-up duration-[800ms] delay-[100ms]">
        <span class="font-display text-sm tracking-wider block mb-3 text-accent">03</span>
        <h2
          class="font-display text-[clamp(2rem,4vw,3rem)] font-normal leading-[1.15] tracking-tight text-card mb-12"
        >
          Built for focus
        </h2>
        <p
          class="font-body text-base font-light leading-relaxed text-[rgba(250,249,246,0.65)] mb-4"
        >
          No notifications. No due-date anxiety. No complex project hierarchies. Just a single,
          peaceful space for the things you intend to do today.
        </p>
        <p class="font-body text-base font-light leading-relaxed text-[rgba(250,249,246,0.65)]">
          If you need more, you already have the right tools. This is for everything else.
        </p>
      </div>
      <div
        class="flex justify-end max-lg:justify-start animate-fade-in-up duration-[800ms] delay-[300ms]"
      >
        <Button href="/app" variant="light">Open the App</Button>
      </div>
    </div>
  </SectionInner>
</section>
