---
import Button from "@/components/ui/Astro/Button.astro";
---

<section class="min-h-screen flex items-center px-8 py-16 max-sm:px-5 relative overflow-hidden">
  <!-- Radial gradient decoration -->
  <div
    class="absolute -top-[20%] -right-[10%] w-[60%] h-[80%] pointer-events-none z-0"
    style="background: radial-gradient(ellipse at center, rgba(237, 234, 227, 0.8) 0%, transparent 70%)"
  >
  </div>

  <div
    class="max-w-[1200px] mx-auto w-full grid grid-cols-[1.1fr_0.9fr] gap-16 items-center relative z-1 max-lg:grid-cols-1 max-lg:gap-12 max-lg:text-center"
  >
    <!-- Text content -->
    <div>
      <p
        class="font-body text-xs font-medium uppercase tracking-[0.15em] text-accent mb-6 animate-fade-in-up duration-[600ms] delay-[100ms]"
      >
        Today&rsquo;s Intentions
      </p>
      <h1
        class="font-display text-[clamp(3rem,6vw,5.5rem)] font-normal leading-[1.05] tracking-tight text-ink mb-6 animate-fade-in-up duration-[800ms] delay-[200ms]"
      >
        Today,<br />
        <em class="text-accent italic">with intention.</em>
      </h1>
      <p
        class="font-body text-[clamp(1.05rem,1.5vw,1.25rem)] font-light leading-relaxed text-ink-secondary max-w-[480px] mb-10 max-lg:mx-auto animate-fade-in-up duration-[800ms] delay-[350ms]"
      >
        Not a task manager. Not a planner. Just a quiet desk for the things you want to do today
        &mdash; so you can come back to them when the world quiets down.
      </p>
      <div
        class="flex gap-4 flex-wrap max-lg:justify-center animate-fade-in-up duration-[800ms] delay-[500ms]"
      >
        <Button href="/app" variant="primary">Open the App</Button>
        <Button href="#how-it-works" variant="secondary">See how it works</Button>
      </div>
    </div>

    <!-- Paper sheet visual -->
    <div
      class="flex justify-center items-center animate-fade-in-up duration-[1000ms] delay-[400ms]"
    >
      <div
        class="paper-sheet bg-card w-full max-w-[380px] p-10 shadow-[0_1px_1px_rgba(0,0,0,0.04),0_4px_8px_rgba(0,0,0,0.04),0_12px_24px_rgba(0,0,0,0.06),0_24px_48px_rgba(0,0,0,0.04)] rotate-[1deg] max-lg:rotate-0 max-sm:p-6 max-sm:max-w-full"
      >
        <div class="flex justify-between items-center mb-8 pl-6 border-b border-line-subtle pb-4">
          <span class="font-body text-xs text-ink-tertiary italic">Monday, June 1</span>
          <span
            class="font-body text-[0.7rem] uppercase tracking-[0.1em] text-ink-tertiary font-medium"
            >Today&rsquo;s Intentions</span
          >
        </div>
        <ul class="paper-list list-none pl-6 max-sm:pl-4">
          <li class="paper-list-item">Write the introduction</li>
          <li class="paper-list-item done">Morning walk by the river</li>
          <li class="paper-list-item">Reply to Maria&#8217;s note</li>
          <li class="paper-list-item done">Read for twenty minutes</li>
          <li class="paper-list-item">Sketch the new layout</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  /* Paper sheet margin line */
  .paper-sheet::before {
    content: "";
    position: absolute;
    top: 0;
    left: 2.5rem;
    bottom: 0;
    width: 1px;
    background: rgba(217, 213, 205, 0.5);
  }

  @media (max-width: 600px) {
    .paper-sheet::before {
      left: 1.5rem;
    }
  }

  /* List item styles */
  .paper-list-item {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-ink);
    padding: 0.6rem 0;
    position: relative;
    border-bottom: 1px solid var(--color-line-subtle);
    transition: all 0.25s ease;
  }

  .paper-list-item:last-child {
    border-bottom: none;
  }

  .paper-list-item::before {
    content: "";
    position: absolute;
    left: -1.5rem;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    border: 1.5px solid var(--color-line);
    border-radius: 2px;
    transition: all 0.25s ease;
  }

  @media (max-width: 600px) {
    .paper-list-item::before {
      left: -1rem;
    }
  }

  .paper-list-item.done {
    color: var(--color-ink-tertiary);
    text-decoration: line-through;
    text-decoration-color: var(--color-line);
  }

  .paper-list-item.done::before {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .paper-list-item.done::after {
    content: "";
    position: absolute;
    left: -1.35rem;
    top: 50%;
    transform: translateY(-60%) rotate(45deg);
    width: 4px;
    height: 7px;
    border-right: 1.5px solid var(--color-card);
    border-bottom: 1.5px solid var(--color-card);
  }

  @media (max-width: 600px) {
    .paper-list-item.done::after {
      left: -0.85rem;
    }
  }
</style>
