---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  showChrome?: boolean;
}

const {
  title,
  description = "A local-first todo app built with Astro and a Solid island.",
  showChrome = true,
} = Astro.props;

const pathname = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/features", label: "Features" },
  { href: "/about", label: "About" },
  { href: "/app", label: "App" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    {
      showChrome ? (
        <div class="min-h-screen">
          <header class="border-b border-stone-200 bg-white">
            <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4 sm:px-6">
              <a class="text-lg font-semibold text-stone-900 no-underline" href="/">
                todo-app
              </a>
              <nav
                aria-label="Primary"
                class="flex flex-wrap items-center gap-3 text-sm text-stone-600"
              >
                {navItems.map((item) => {
                  const isCurrent = pathname === item.href;

                  return (
                    <a
                      href={item.href}
                      aria-current={isCurrent ? "page" : undefined}
                      class:list={{
                        "font-medium text-stone-900": isCurrent,
                        "no-underline hover:text-stone-900": true,
                      }}
                    >
                      {item.label}
                    </a>
                  );
                })}
              </nav>
            </div>
          </header>

          <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
            <slot />
          </main>
        </div>
      ) : (
        <slot />
      )
    }
  </body>
</html>
