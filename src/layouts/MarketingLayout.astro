---
import Fonts from "@/components/Fonts.astro";
import "@/styles/marketing.css";
import { ClientRouter } from "astro:transitions";

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "A calm scratchpad for today's intentions." } = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/features", label: "Features" },
  { href: "/about", label: "About" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <Fonts />
    <ClientRouter fallback="animate" />
  </head>
  <body
    class="bg-mk-surface font-mk-body text-mk-text leading-relaxed overflow-x-hidden antialiased"
  >
    <!-- Fixed Header -->
    <header
      transition:animate="initial"
      class="fixed inset-x-0 top-0 z-[100] bg-mk-surface/92 backdrop-blur-[12px] border-b border-mk-border-light animate-mk-fade-in"
    >
      <div
        class="max-w-[1200px] mx-auto px-8 h-16 max-sm:px-5 max-sm:h-14 flex items-center justify-between"
      >
        <a href="/" class="font-mk-display text-xl text-mk-text tracking-tight">todo-app</a>
        <nav class="flex gap-1 max-sm:gap-[0.1rem] items-center" aria-label="Primary">
          {
            navItems.map((item) => {
              const isCurrent =
                pathname === item.href || (item.href !== "/" && pathname.startsWith(item.href));
              return (
                <a
                  href={item.href}
                  class:list={[
                    "font-mk-body text-sm max-sm:text-[0.8rem] font-normal text-mk-text-secondary px-[0.7rem] max-sm:px-[0.5rem] py-[0.4rem] max-sm:py-[0.3rem] rounded-[2px] transition-all duration-300",
                    isCurrent
                      ? "text-mk-accent bg-[rgba(107,45,58,0.06)] font-medium"
                      : "hover:text-mk-text hover:bg-mk-warm",
                  ]}
                  aria-current={isCurrent ? "page" : undefined}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
        <a
          href="/app"
          class="font-mk-body text-sm max-sm:text-[0.8rem] font-medium text-mk-accent px-5 max-sm:px-[0.9rem] py-2 max-sm:py-[0.4rem] border border-mk-accent rounded-[2px] transition-all duration-300 hover:bg-mk-accent hover:text-mk-paper"
        >
          Open App
        </a>
      </div>
    </header>

    <main transition:animate="slide">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-mk-text text-mk-warm px-8 py-12 max-sm:px-5">
      <div
        class="max-w-[1200px] mx-auto flex justify-between items-center flex-wrap gap-6 max-sm:flex-col max-sm:text-center"
      >
        <div class="flex flex-col gap-1">
          <span class="font-mk-display text-[1.1rem] text-mk-paper">todo-app</span>
          <span class="font-mk-body text-xs text-mk-text-muted tracking-wide">
            A scratchpad for today's intentions.
          </span>
        </div>
        <nav class="flex gap-6 max-sm:flex-wrap max-sm:justify-center" aria-label="Footer">
          <a
            href="/"
            class="font-mk-body text-[0.8rem] text-mk-text-muted transition-colors duration-300 hover:text-mk-paper"
          >
            Home
          </a>
          <a
            href="/features"
            class="font-mk-body text-[0.8rem] text-mk-text-muted transition-colors duration-300 hover:text-mk-paper"
          >
            Features
          </a>
          <a
            href="/about"
            class="font-mk-body text-[0.8rem] text-mk-text-muted transition-colors duration-300 hover:text-mk-paper"
          >
            About
          </a>
          <a
            href="/app"
            class="font-mk-body text-[0.8rem] text-mk-text-muted transition-colors duration-300 hover:text-mk-paper"
          >
            App
          </a>
        </nav>
        <div>
          <a
            href="/app"
            class="font-mk-body text-sm font-medium text-mk-paper border-b border-[rgba(250,249,246,0.2)] pb-[0.1rem] transition-all duration-300 hover:border-mk-paper"
          >
            Open the App &rarr;
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
