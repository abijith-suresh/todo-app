---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="About | todo-app"
  description="About todo-app — a calm scratchpad for today's intentions."
>
  <!-- Page Header -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-kicker">About</p>
      <h1 class="page-title">
        Made for the days<br /><em class="italic-accent">that slip away.</em>
      </h1>
      <p class="page-subhead">
        todo-app was born from a simple observation: the most meaningful things we want to do today
        rarely need a project management suite.
      </p>
    </div>
  </section>

  <!-- Story Section -->
  <section class="section section-light">
    <div class="section-inner">
      <div class="story-layout">
        <div class="story-text">
          <span class="section-number">01</span>
          <h2 class="section-title">The idea</h2>
          <p class="story-body">
            We kept opening heavy task managers to write down simple things like
            <em>call the dentist</em> or <em>sketch the garden plan</em>. Those tools were built for
            teams, sprints, and dashboards — not for a single human trying to hold onto a thought
            until evening.
          </p>
          <p class="story-body">
            todo-app is the opposite. No accounts. No sync servers. No notifications buzzing at
            midnight. Just a quiet page that remembers what you wrote this morning.
          </p>
        </div>
        <div class="story-visual">
          <div class="paper-card">
            <span class="paper-card-label">A note to self</span>
            <p class="paper-card-text">
              "The best tools are the ones you forget you're using. I want todo-app to feel like the
              back of an envelope — always within reach, never in the way."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Principles Section -->
  <section class="section section-accent">
    <div class="section-inner">
      <div class="principles-header">
        <span class="section-number">02</span>
        <h2 class="section-title">What we believe</h2>
      </div>
      <div class="principles-grid">
        <div class="principle">
          <h3 class="principle-title">Local-first</h3>
          <p class="principle-body">
            Your data lives in your browser. We don't store anything on our servers because there
            are no servers.
          </p>
        </div>
        <div class="principle">
          <h3 class="principle-title">Friction-free</h3>
          <p class="principle-body">
            No sign-up forms. No onboarding wizards. Open the page and start writing.
          </p>
        </div>
        <div class="principle">
          <h3 class="principle-title">Today, only today</h3>
          <p class="principle-body">
            We don't do recurring tasks, Gantt charts, or team collaboration. This is a single page
            for a single day.
          </p>
        </div>
        <div class="principle">
          <h3 class="principle-title">Quiet by design</h3>
          <p class="principle-body">
            No badges, no red dots, no urgency. If it matters, you'll remember it. The rest can
            wait.
          </p>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ============================================
       Page Hero
       ============================================ */
    .page-hero {
      min-height: 60vh;
      display: flex;
      align-items: center;
      padding: 8rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: "";
      position: absolute;
      top: -20%;
      right: -10%;
      width: 60%;
      height: 80%;
      background: radial-gradient(ellipse at center, rgba(237, 234, 227, 0.8) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    .page-hero-inner {
      max-width: 1000px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 1;
    }

    .page-kicker {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeInUp 0.6s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .page-title {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeInUp 0.8s 0.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .italic-accent {
      font-style: italic;
      color: var(--accent);
    }

    .page-subhead {
      font-family: var(--font-body);
      font-size: clamp(1rem, 1.4vw, 1.15rem);
      font-weight: 300;
      line-height: 1.7;
      color: var(--text-secondary);
      max-width: 520px;
      opacity: 0;
      animation: fadeInUp 0.8s 0.35s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    /* ============================================
       Story Section
       ============================================ */
    .story-layout {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem;
      align-items: start;
    }

    .story-text {
      opacity: 0;
      animation: fadeInUp 0.8s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .story-body {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 300;
      line-height: 1.7;
      color: var(--text-secondary);
      margin-bottom: 1.25rem;
    }

    .story-body em {
      font-style: italic;
      color: var(--text-primary);
    }

    .story-visual {
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding-top: 2rem;
      opacity: 0;
      animation: fadeInUp 0.8s 0.3s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .paper-card {
      background: var(--bg-paper);
      padding: 2rem;
      border: 1px solid var(--border-light);
      border-radius: var(--radius);
      box-shadow: var(--shadow-soft);
      max-width: 340px;
      position: relative;
    }

    .paper-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 2rem;
      bottom: 0;
      width: 1px;
      background: rgba(217, 213, 205, 0.5);
    }

    .paper-card-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      font-weight: 500;
      display: block;
      margin-bottom: 1rem;
      padding-left: 1.25rem;
    }

    .paper-card-text {
      font-family: var(--font-body);
      font-size: 0.95rem;
      font-style: italic;
      line-height: 1.6;
      color: var(--text-primary);
      padding-left: 1.25rem;
    }

    /* ============================================
       Principles Section
       ============================================ */
    .principles-header {
      margin-bottom: 3rem;
      opacity: 0;
      animation: fadeInUp 0.8s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .principles-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }

    .principle {
      opacity: 0;
      animation: fadeInUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .principle:nth-child(1) {
      animation-delay: 0.1s;
    }
    .principle:nth-child(2) {
      animation-delay: 0.2s;
    }
    .principle:nth-child(3) {
      animation-delay: 0.3s;
    }
    .principle:nth-child(4) {
      animation-delay: 0.4s;
    }

    .principle-title {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 400;
      margin-bottom: 0.75rem;
      color: var(--bg-paper);
    }

    .principle-body {
      font-family: var(--font-body);
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.65;
      color: rgba(250, 249, 246, 0.65);
    }

    /* ============================================
       Responsive
       ============================================ */
    @media (max-width: 900px) {
      .story-layout {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .principles-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    @media (max-width: 600px) {
      .page-hero {
        padding: 7rem 1.25rem 3rem;
      }

      .paper-card {
        padding: 1.5rem;
        max-width: 100%;
      }

      .paper-card::before {
        left: 1.5rem;
      }

      .paper-card-label,
      .paper-card-text {
        padding-left: 1rem;
      }
    }
  </style>
</MarketingLayout>
