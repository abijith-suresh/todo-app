---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
---

<MarketingLayout
  title="todo-app — Today's Intentions"
  description="A calm place to jot down what you want to do today."
>
  <!-- Hero Section -->
  <section class="hero" id="hero">
    <div class="hero-content">
      <div class="hero-text">
        <p class="hero-kicker">Today's Intentions</p>
        <h1 class="hero-headline">
          Today,<br />
          <em class="italic-accent">with intention.</em>
        </h1>
        <p class="hero-subhead">
          Not a task manager. Not a planner. Just a quiet desk for the things you want to do today —
          so you can come back to them when the world quiets down.
        </p>
        <div class="hero-actions">
          <a href="/app" class="btn btn-primary">Open the App</a>
          <a href="#how-it-works" class="btn btn-secondary">See how it works</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="paper-sheet">
          <div class="paper-header">
            <span class="paper-date">Monday, June 1</span>
            <span class="paper-label">Today's Intentions</span>
          </div>
          <ul class="paper-list">
            <li>Write the introduction</li>
            <li class="done">Morning walk by the river</li>
            <li>Reply to Maria's note</li>
            <li class="done">Read for twenty minutes</li>
            <li>Sketch the new layout</li>
          </ul>
          <div class="paper-margin"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section class="section section-light" id="how-it-works">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">How it works</h2>
      </div>
      <div class="steps">
        <div class="step">
          <h3 class="step-title">Open the page</h3>
          <p class="step-desc">
            No sign-up, no onboarding, no clutter. You land on a clean sheet and the cursor is
            already blinking.
          </p>
        </div>
        <div class="step">
          <h3 class="step-title">Write your intentions</h3>
          <p class="step-desc">
            Jot down what you want to do today. One line or ten. There is no wrong way to begin.
          </p>
        </div>
        <div class="step">
          <h3 class="step-title">Return as needed</h3>
          <p class="step-desc">
            Close the tab, open it again. Your today's list is right where you left it — a quiet
            companion.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy Section -->
  <section class="section section-accent">
    <div class="section-inner">
      <div class="philosophy-layout">
        <div class="philosophy-text">
          <span class="section-number">02</span>
          <h2 class="section-title">Why it matters</h2>
          <p class="philosophy-lead">
            Most tools want to manage your life. We only want to hold your today's thoughts so you
            can focus on doing them, not organizing them.
          </p>
          <p class="philosophy-body">
            The best ideas arrive unannounced. The most important tasks rarely have a deadline.
            todo-app is a single page for a single day — a scratchpad for the things that matter
            before they slip into tomorrow's regret.
          </p>
          <p class="philosophy-body">
            Close it when you're done. Open it when you need it. Nothing more.
          </p>
        </div>
        <div class="philosophy-visual">
          <blockquote class="editorial-quote">
            <span class="quote-mark">&ldquo;</span>
            <p>
              The list you make in the morning is a letter to your future self. Write it kindly.
            </p>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ============================================
       Hero Section
       ============================================ */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding: 8rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: "";
      position: absolute;
      top: -20%;
      right: -10%;
      width: 60%;
      height: 80%;
      background: radial-gradient(ellipse at center, rgba(237, 234, 227, 0.8) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    .hero-content {
      max-width: 1200px;
      margin: 0 auto;
      width: 100%;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .hero-kicker {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeInUp 0.6s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(3rem, 6vw, 5.5rem);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeInUp 0.8s 0.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .italic-accent {
      font-style: italic;
      color: var(--accent);
    }

    .hero-subhead {
      font-family: var(--font-body);
      font-size: clamp(1.05rem, 1.5vw, 1.25rem);
      font-weight: 300;
      line-height: 1.7;
      color: var(--text-secondary);
      max-width: 480px;
      margin-bottom: 2.5rem;
      opacity: 0;
      animation: fadeInUp 0.8s 0.35s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      opacity: 0;
      animation: fadeInUp 0.8s 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    /* Hero Visual — Paper Sheet */
    .hero-visual {
      display: flex;
      justify-content: center;
      align-items: center;
      opacity: 0;
      animation: fadeInUp 1s 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .paper-sheet {
      background: var(--bg-paper);
      width: 100%;
      max-width: 380px;
      padding: 2.5rem;
      box-shadow:
        0 1px 1px rgba(0, 0, 0, 0.04),
        0 4px 8px rgba(0, 0, 0, 0.04),
        0 12px 24px rgba(0, 0, 0, 0.06),
        0 24px 48px rgba(0, 0, 0, 0.04);
      position: relative;
      transform: rotate(1deg);
      border-radius: var(--radius);
    }

    .paper-sheet::before {
      content: "";
      position: absolute;
      top: 0;
      left: 2.5rem;
      bottom: 0;
      width: 1px;
      background: rgba(217, 213, 205, 0.5);
    }

    .paper-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      padding-left: 1.5rem;
      border-bottom: 1px solid var(--border-light);
      padding-bottom: 1rem;
    }

    .paper-date {
      font-family: var(--font-body);
      font-size: 0.75rem;
      color: var(--text-muted);
      font-style: italic;
    }

    .paper-label {
      font-family: var(--font-body);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
      font-weight: 500;
    }

    .paper-list {
      list-style: none;
      padding-left: 1.5rem;
    }

    .paper-list li {
      font-family: var(--font-body);
      font-size: 0.95rem;
      color: var(--text-primary);
      padding: 0.6rem 0;
      position: relative;
      border-bottom: 1px solid var(--border-light);
      transition: all 0.25s ease;
    }

    .paper-list li:last-child {
      border-bottom: none;
    }

    .paper-list li::before {
      content: "";
      position: absolute;
      left: -1.5rem;
      top: 50%;
      transform: translateY(-50%);
      width: 10px;
      height: 10px;
      border: 1.5px solid var(--border);
      border-radius: 2px;
      transition: all 0.25s ease;
    }

    .paper-list li.done {
      color: var(--text-muted);
      text-decoration: line-through;
      text-decoration-color: var(--border);
    }

    .paper-list li.done::before {
      background: var(--accent);
      border-color: var(--accent);
    }

    .paper-list li.done::after {
      content: "";
      position: absolute;
      left: -1.35rem;
      top: 50%;
      transform: translateY(-60%) rotate(45deg);
      width: 4px;
      height: 7px;
      border-right: 1.5px solid var(--bg-paper);
      border-bottom: 1.5px solid var(--bg-paper);
    }

    /* ============================================
       How It Works — Steps
       ============================================ */
    .steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }

    .step {
      opacity: 0;
      animation: fadeInUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .step:nth-child(1) {
      animation-delay: 0.1s;
    }
    .step:nth-child(2) {
      animation-delay: 0.25s;
    }
    .step:nth-child(3) {
      animation-delay: 0.4s;
    }

    .step-title {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 400;
      margin-bottom: 0.75rem;
      color: var(--text-primary);
    }

    .step-desc {
      font-family: var(--font-body);
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.65;
      color: var(--text-secondary);
    }

    /* ============================================
       Philosophy Section
       ============================================ */
    .philosophy-layout {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem;
      align-items: start;
    }

    .philosophy-text {
      opacity: 0;
      animation: fadeInUp 0.8s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .philosophy-lead {
      font-family: var(--font-display);
      font-size: clamp(1.25rem, 2vw, 1.5rem);
      line-height: 1.5;
      margin-bottom: 1.5rem;
      color: rgba(250, 249, 246, 0.95);
    }

    .philosophy-body {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 300;
      line-height: 1.7;
      color: rgba(250, 249, 246, 0.65);
      margin-bottom: 1rem;
    }

    .philosophy-visual {
      display: flex;
      align-items: center;
      justify-content: center;
      padding-top: 2rem;
      opacity: 0;
      animation: fadeInUp 0.8s 0.3s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .editorial-quote {
      position: relative;
      padding: 2rem;
      border-left: 2px solid rgba(250, 249, 246, 0.15);
    }

    .quote-mark {
      font-family: var(--font-display);
      font-size: 4rem;
      line-height: 1;
      color: rgba(250, 249, 246, 0.15);
      position: absolute;
      top: 0.5rem;
      left: 1.5rem;
    }

    .editorial-quote p {
      font-family: var(--font-body);
      font-size: 1.1rem;
      font-style: italic;
      line-height: 1.6;
      color: rgba(250, 249, 246, 0.8);
      position: relative;
      z-index: 1;
    }

    /* ============================================
       Responsive
       ============================================ */
    @media (max-width: 900px) {
      .hero-content {
        grid-template-columns: 1fr;
        gap: 3rem;
        text-align: center;
      }

      .hero-subhead {
        margin-left: auto;
        margin-right: auto;
      }

      .hero-actions {
        justify-content: center;
      }

      .hero-visual {
        order: -1;
      }

      .paper-sheet {
        max-width: 320px;
        transform: rotate(0deg);
      }

      .steps {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .philosophy-layout {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .editorial-quote {
        padding: 1.5rem;
      }
    }

    @media (max-width: 600px) {
      .hero {
        padding: 7rem 1.25rem 3rem;
      }

      .paper-sheet {
        padding: 1.5rem;
        max-width: 100%;
      }

      .paper-sheet::before {
        left: 1.5rem;
      }

      .paper-list {
        padding-left: 1rem;
      }

      .paper-list li::before {
        left: -1rem;
      }

      .paper-list li.done::after {
        left: -0.85rem;
      }
    }
  </style>
</MarketingLayout>
