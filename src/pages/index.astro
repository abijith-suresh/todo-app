---
import PageIntro from "@/features/marketing/components/PageIntro.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout
  title="todo-app"
  description="A local-first todo app running inside an Astro site with a Solid island at /app."
>
  <section class="space-y-6">
    <PageIntro
      eyebrow="Local-first task management"
      title="A small Astro site around the existing Solid app."
      description="The interactive task app now lives at /app. The rest of the site is a minimal Astro shell with a few static pages."
    />

    <div class="flex flex-wrap gap-3">
      <a
        class="rounded-md bg-stone-900 px-4 py-2 text-sm font-medium text-white no-underline"
        href="/app"
      >
        Open the app
      </a>
      <a
        class="rounded-md border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline"
        href="/features"
      >
        View features
      </a>
    </div>
  </section>
</SiteLayout>
