---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="todo-app"
  description="A local-first todo app running inside an Astro site with a Solid island at /app."
>
  <section class="space-y-6">
    <div class="space-y-3">
      <p class="text-sm font-medium uppercase tracking-wide text-stone-500">
        Local-first task management
      </p>
      <h1 class="text-4xl font-semibold tracking-tight text-stone-900">
        A small Astro site around the existing Solid app.
      </h1>
      <p class="max-w-2xl text-base leading-7 text-stone-600">
        The interactive task app now lives at <code>/app</code>. The rest of the site is a minimal
        Astro shell with a few static pages.
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      <a
        class="rounded-md bg-stone-900 px-4 py-2 text-sm font-medium text-white no-underline"
        href="/app"
      >
        Open the app
      </a>
      <a
        class="rounded-md border border-stone-300 px-4 py-2 text-sm font-medium text-stone-700 no-underline"
        href="/features"
      >
        View features
      </a>
    </div>
  </section>
</BaseLayout>
