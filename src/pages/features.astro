---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import PageHeader from "@/components/marketing/composites/PageHeader.astro";
import FeatureGrid from "@/components/marketing/composites/FeatureGrid.astro";
import ClosingSection from "@/components/marketing/composites/ClosingSection.astro";
---

<MarketingLayout
  title="Features | todo-app"
  description="Core features of todo-app — a calm scratchpad for today's intentions."
>
  <PageHeader
    kicker="Features"
    titlePrefix="Everything you need,"
    titleEmphasis="nothing you don't."
    subtitle="We stripped away the noise of traditional task managers so you can focus on one thing: today."
  />
  <FeatureGrid />
  <ClosingSection />
</MarketingLayout>
