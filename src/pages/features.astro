---
import MarketingLayout from "@/layouts/MarketingLayout.astro";

const featureItems = [
  "Inbox, Today, Upcoming, and project views",
  "Independent when and due dates",
  "IndexedDB-backed local storage",
  "Keyboard shortcuts, fuzzy search, and quick add",
  "Project and task ordering with drag and drop",
  "Theme toggle plus JSON import and export",
];
---

<MarketingLayout
  title="Features | todo-app"
  description="Core features of todo-app — a calm scratchpad for today's intentions."
>
  <!-- Page Header -->
  <section class="page-hero">
    <div class="page-hero-inner">
      <p class="page-kicker">Features</p>
      <h1 class="page-title">
        Everything you need,<br /><em class="italic-accent">nothing you don't.</em>
      </h1>
      <p class="page-subhead">
        We stripped away the noise of traditional task managers so you can focus on one thing:
        today.
      </p>
    </div>
  </section>

  <!-- Feature List -->
  <section class="section section-light">
    <div class="section-inner">
      <div class="feature-grid">
        {
          featureItems.map((item, i) => (
            <div class="feature-card" style={`animation-delay: ${0.1 + i * 0.1}s`}>
              <span class="feature-number">{String(i + 1).padStart(2, "0")}</span>
              <p class="feature-text">{item}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Philosophy Strip -->
  <section class="section section-accent">
    <div class="section-inner">
      <div class="closing-layout">
        <div class="closing-text">
          <span class="section-number">03</span>
          <h2 class="section-title">Built for focus</h2>
          <p class="closing-body">
            No notifications. No due-date anxiety. No complex project hierarchies. Just a single,
            peaceful space for the things you intend to do today.
          </p>
          <p class="closing-body">
            If you need more, you already have the right tools. This is for everything else.
          </p>
        </div>
        <div class="closing-cta">
          <a href="/app" class="btn btn-primary btn-on-accent">Open the App</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* ============================================
       Page Hero
       ============================================ */
    .page-hero {
      min-height: 60vh;
      display: flex;
      align-items: center;
      padding: 8rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }

    .page-hero::before {
      content: "";
      position: absolute;
      top: -20%;
      right: -10%;
      width: 60%;
      height: 80%;
      background: radial-gradient(ellipse at center, rgba(237, 234, 227, 0.8) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    .page-hero-inner {
      max-width: 1000px;
      margin: 0 auto;
      width: 100%;
      position: relative;
      z-index: 1;
    }

    .page-kicker {
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--accent);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeInUp 0.6s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .page-title {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      opacity: 0;
      animation: fadeInUp 0.8s 0.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .italic-accent {
      font-style: italic;
      color: var(--accent);
    }

    .page-subhead {
      font-family: var(--font-body);
      font-size: clamp(1rem, 1.4vw, 1.15rem);
      font-weight: 300;
      line-height: 1.7;
      color: var(--text-secondary);
      max-width: 520px;
      opacity: 0;
      animation: fadeInUp 0.8s 0.35s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    /* ============================================
       Feature Grid
       ============================================ */
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .feature-card {
      background: var(--bg-paper);
      padding: 2rem;
      border-radius: var(--radius);
      border: 1px solid var(--border-light);
      opacity: 0;
      animation: fadeInUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      transition:
        transform 0.3s ease,
        box-shadow 0.3s ease;
    }

    .feature-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-soft);
    }

    .feature-number {
      font-family: var(--font-display);
      font-size: 0.875rem;
      color: var(--accent);
      letter-spacing: 0.05em;
      display: block;
      margin-bottom: 0.75rem;
    }

    .feature-text {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 400;
      line-height: 1.5;
      color: var(--text-primary);
    }

    /* ============================================
       Closing Section
       ============================================ */
    .closing-layout {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem;
      align-items: center;
    }

    .closing-text {
      opacity: 0;
      animation: fadeInUp 0.8s 0.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .closing-body {
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 300;
      line-height: 1.7;
      color: rgba(250, 249, 246, 0.65);
      margin-bottom: 1rem;
    }

    .closing-cta {
      display: flex;
      justify-content: flex-end;
      opacity: 0;
      animation: fadeInUp 0.8s 0.3s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .btn-on-accent {
      background: var(--bg-paper);
      color: var(--accent);
    }

    .btn-on-accent:hover {
      background: rgba(250, 249, 246, 0.9);
      color: var(--accent-hover);
    }

    /* ============================================
       Responsive
       ============================================ */
    @media (max-width: 900px) {
      .feature-grid {
        grid-template-columns: 1fr;
      }

      .closing-layout {
        grid-template-columns: 1fr;
        gap: 2rem;
      }

      .closing-cta {
        justify-content: flex-start;
      }
    }

    @media (max-width: 600px) {
      .page-hero {
        padding: 7rem 1.25rem 3rem;
      }

      .feature-card {
        padding: 1.5rem;
      }
    }
  </style>
</MarketingLayout>
