---
import BaseLayout from "../layouts/BaseLayout.astro";

const features = [
  "Inbox, Today, Upcoming, and project views",
  "Independent when and due dates",
  "IndexedDB-backed local storage",
  "Keyboard shortcuts, fuzzy search, and quick add",
  "Project and task ordering with drag and drop",
  "Theme toggle plus JSON import and export",
];
---

<BaseLayout
  title="Features | todo-app"
  description="Core features available in the Solid todo app."
>
  <section class="max-w-3xl space-y-6">
    <div class="space-y-3">
      <h1 class="text-3xl font-semibold tracking-tight text-stone-900">Features</h1>
      <p class="text-base leading-7 text-stone-600">
        The Solid island at <code>/app</code> keeps the existing task workflow intact.
      </p>
    </div>

    <ul class="space-y-3 rounded-lg border border-stone-200 bg-white p-6 text-stone-700">
      {features.map((feature) => <li>{feature}</li>)}
    </ul>
  </section>
</BaseLayout>
