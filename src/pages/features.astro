---
import FeatureList from "@/features/marketing/components/FeatureList.astro";
import PageIntro from "@/features/marketing/components/PageIntro.astro";
import { featureItems } from "@/features/marketing/content/site";
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout
  title="Features | todo-app"
  description="Core features available in the Solid todo app."
>
  <section class="max-w-3xl space-y-6">
    <PageIntro
      title="Features"
      description="The Solid island at /app keeps the existing task workflow intact."
    />
    <FeatureList items={featureItems} />
  </section>
</SiteLayout>
