---
import AppIsland from "../components/AppIsland";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="App | todo-app"
  description="The existing Solid todo app mounted as a client-only Astro island."
  showChrome={false}
>
  <AppIsland client:only="solid-js">
    <div class="flex min-h-screen items-center justify-center px-6 text-sm text-stone-600">
      Loading the app...
    </div>
  </AppIsland>
</BaseLayout>
