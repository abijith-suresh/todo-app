---
import { siteNavItems } from "../content/site";

const pathname = Astro.url.pathname;
---

<header class="border-b border-stone-200 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4 sm:px-6">
    <a class="text-lg font-semibold text-stone-900 no-underline" href="/"> todo-app </a>

    <nav aria-label="Primary" class="flex flex-wrap items-center gap-3 text-sm text-stone-600">
      {
        siteNavItems.map((item) => {
          const isCurrent = pathname === item.href;

          return (
            <a
              href={item.href}
              aria-current={isCurrent ? "page" : undefined}
              class:list={{
                "font-medium text-stone-900": isCurrent,
                "no-underline hover:text-stone-900": true,
              }}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
