---
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<div class="space-y-3">
  {
    eyebrow ? (
      <p class="text-sm font-medium uppercase tracking-wide text-stone-500">{eyebrow}</p>
    ) : null
  }
  <h1 class="text-3xl font-semibold tracking-tight text-stone-900 sm:text-4xl">{title}</h1>
  <p class="max-w-2xl text-base leading-7 text-stone-600">{description}</p>
</div>
